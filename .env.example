# ── Community features (votes + chat). Optional — the site runs without these. ──

# Clerk auth — create an application at https://dashboard.clerk.com, then copy keys:
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx

# Neon / Vercel Postgres connection string (from the Vercel dashboard or neon.tech).
# After setting this, run: npm run db:migrate
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
